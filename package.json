{
  "name": "claudebot-app",
  "version": "0.1.0",
  "description": "Telegram Bot to remotely control Claude Code CLI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "claudebot": "bin/cli.mjs"
  },
  "files": [
    "bin/cli.mjs"
  ],
  "scripts": {
    "dev": "tsx src/launcher.ts",
    "dev:single": "tsx src/index.ts",
    "build": "tsc && npx esbuild src/remote/electron/main.ts --bundle --platform=node --format=cjs --outfile=dist/remote/electron/main.cjs --external:electron --external:ws --external:../tool-handlers.js && node -e \"require('fs').copyFileSync('src/remote/electron/launch-electron.cjs','dist/remote/electron/launch-electron.cjs')\"",
    "start": "node dist/index.js",
    "dashboard": "tsx src/dashboard/start.ts",
    "setup": "tsx src/setup.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "remote": "tsx src/remote/agent.ts",
    "electron:dev": "electron dist/remote/electron/main.cjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "ffmpeg-static": "^5.3.0",
    "localtunnel": "^2.0.2",
    "playwright": "^1.58.2",
    "rebrowser-playwright": "^1.52.0",
    "telegraf": "^4.16.3",
    "undici": "^7.22.0",
    "ws": "^8.19.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/localtunnel": "^2.0.4",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  }
}
