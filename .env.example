# ═══════════════════════════════════════════════════════════════
#  ClaudeBot — .env.example
#  Copy to .env and fill in your values:  cp .env.example .env
#  Or use the setup wizard:               npm run setup
# ═══════════════════════════════════════════════════════════════

# ── Required 必填 ─────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram chat IDs allowed to use the bot
# 允許使用的 Telegram 使用者 ID（用逗號分隔）
ALLOWED_CHAT_IDS=123456789

# Base directory containing your projects (comma-separated for multiple)
# 專案資料夾路徑（可用逗號分隔多個）
PROJECTS_BASE_DIR=/path/to/your/projects

# ── Authentication 身份驗證 ───────────────────────────────────

# Login password (plain text - for quick setup)
# 登入密碼（擇一設定即可）
LOGIN_PASSWORD=changeme

# Or use a bcrypt hash (recommended for production):
# LOGIN_PASSWORD_HASH=$2b$10$... (generate with: node -e "require('bcrypt').hash('pw',10).then(console.log)")

# Auto-authenticate whitelisted chats (skip /login)
# 自動驗證白名單使用者（跳過 /login）
AUTO_AUTH=true

# ── AI Settings AI 設定 ──────────────────────────────────────

# Default Claude model: haiku (fast) / sonnet (balanced) / opus (powerful)
DEFAULT_MODEL=sonnet

# Max Claude conversation turns (optional)
# Claude 對話最大回合數
# MAX_TURNS=

# Gemini API Key (optional — enables Gemini backend, free tier: 1000 req/day)
# GEMINI_API_KEY=

# Anthropic Admin API key (optional — enables /usage org-level billing)
# ANTHROPIC_ADMIN_KEY=

# ── Plugins & Features 插件與功能 ────────────────────────────

# Plugins to enable (comma-separated)
# 啟用的插件（用逗號分隔）
PLUGINS=screenshot,dice,reminder,sysinfo,browse,cost

# Rate limit: max messages per window
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# GitHub personal access token (optional — enables github plugin features)
# GITHUB_TOKEN=

# Admin chat ID for system notifications (optional)
# 管理員通知 chat ID
# ADMIN_CHAT_ID=

# Auto git commit+push after AI changes (optional)
# AI 改動後自動 git commit+push
AUTO_COMMIT=false

# ── Dashboard 控制面板 ───────────────────────────────────────

# Web dashboard on :3100 (optional)
DASHBOARD=false
DASHBOARD_PORT=3100

# ── Voice Recognition 語音辨識 ───────────────────────────────

# Sherpa-ONNX server path (required for voice features)
# 語音辨識 server 路徑（需要語音功能才要設定）
# SHERPA_SERVER_PATH=/path/to/sherpa-onnx-online-websocket-server

# Punctuation tool path (optional — rule-based Chinese punctuation)
# 標點符號修正工具路徑（可選）
# BIAODIAN_PATH=/path/to/biaodian/biaodian.py

# ── Advanced 進階設定 ────────────────────────────────────────

# Prevent system sleep while bot is running (optional)
# 防止系統休眠
PREVENT_SLEEP=false

# MCP browser integration (optional)
MCP_BROWSER=false

# Skip Claude CLI permission prompts
SKIP_PERMISSIONS=true

# Pinchtab browser API (optional — fallback to Playwright if unavailable)
# PINCHTAB_URL=http://localhost:9867

# Plugin registry URL (default: GitHub raw)
# PLUGIN_REGISTRY_URL=https://raw.githubusercontent.com/Jeffrey0117/claudebot-plugins/master/registry.json
